---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const posts = [
  {
    title: "Comment digitaliser la gestion de votre flotte de taxis",
    excerpt: "Guide complet pour les syndicats et propriétaires souhaitant moderniser leur gestion et améliorer leur rentabilité.",
    date: "15 Mars 2026",
    category: "Guide",
    readTime: "8 min",
    slug: "digitaliser-flotte-taxis"
  },
  {
    title: "Les défis de la conformité documentaire des taxis en Afrique",
    excerpt: "Visite technique, patente, assurance : comment gérer efficacement les documents obligatoires et éviter les sanctions.",
    date: "10 Mars 2026",
    category: "Conformité",
    readTime: "6 min",
    slug: "conformite-documentaire-afrique"
  },
  {
    title: "Success story : Le syndicat de Grand-Bassam passe au digital",
    excerpt: "Comment le syndicat des taxis de Grand-Bassam a amélioré sa gestion et réduit les retards de versements de 30%.",
    date: "5 Mars 2026",
    category: "Témoignage",
    readTime: "5 min",
    slug: "success-story-grand-bassam"
  }
];
---

<Layout title="Blog - AfriMobilis" description="Actualités, guides et conseils sur la digitalisation des taxis en Afrique">
  <Header />
  
  <main class="pt-32 pb-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header -->
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h1 class="text-4xl font-bold text-slate-900 mb-4">Blog AfriMobilis</h1>
        <p class="text-lg text-slate-600">
          Actualités, guides et conseils sur la digitalisation des taxis en Afrique
        </p>
      </div>

      <!-- Posts Grid -->
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.map((post) => (
          <article class="bg-white rounded-2xl overflow-hidden border border-slate-200 hover:shadow-lg transition">
            <div class="h-48 bg-gradient-to-br from-sky-100 to-blue-100 flex items-center justify-center">
              <span class="text-6xl">📝</span>
            </div>
            <div class="p-6">
              <div class="flex items-center gap-3 mb-3">
                <span class="text-xs font-semibold text-sky-600 bg-sky-100 px-3 py-1 rounded-full">
                  {post.category}
                </span>
                <span class="text-xs text-slate-500">{post.readTime} de lecture</span>
              </div>
              <h2 class="text-xl font-bold text-slate-900 mb-2 line-clamp-2">
                <a href={`/blog/${post.slug}`} class="hover:text-sky-600 transition">
                  {post.title}
                </a>
              </h2>
              <p class="text-slate-600 mb-4 line-clamp-3">{post.excerpt}</p>
              <time class="text-sm text-slate-500">{post.date}</time>
            </div>
          </article>
        ))}
      </div>

      <!-- Newsletter -->
      <div class="mt-16 bg-slate-900 rounded-2xl p-8 md:p-12 text-center">
        <h2 class="text-2xl font-bold text-white mb-4">Restez informé</h2>
        <p class="text-slate-300 mb-6">Recevez nos derniers articles et actualités directement dans votre boîte mail.</p>
        <form class="flex flex-col sm:flex-row gap-4 max-w-md mx-auto">
          <input 
            type="email" 
            placeholder="Votre email"
            class="flex-1 px-4 py-3 rounded-lg bg-slate-800 border border-slate-700 text-white placeholder-slate-500 focus:ring-2 focus:ring-sky-500 outline-none"
          />
          <button type="submit" class="bg-sky-600 hover:bg-sky-700 text-white px-6 py-3 rounded-lg font-semibold transition">
            S'abonner
          </button>
        </form>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
