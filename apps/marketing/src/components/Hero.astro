---
---
<section class="relative pt-32 pb-20 lg:pt-40 lg:pb-32 overflow-hidden">
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-gradient-to-br from-sky-50 via-white to-blue-50"></div>
  
  <!-- Decorative elements -->
  <div class="absolute top-20 right-0 w-96 h-96 bg-sky-400/10 rounded-full blur-3xl"></div>
  <div class="absolute bottom-0 left-0 w-96 h-96 bg-blue-400/10 rounded-full blur-3xl"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-4xl mx-auto">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 bg-sky-100 text-sky-700 px-4 py-2 rounded-full text-sm font-semibold mb-8">
        <span class="w-2 h-2 bg-sky-500 rounded-full animate-pulse"></span>
        Lancé à Grand-Bassam - Expansion en cours
      </div>

      <!-- Headline -->
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-slate-900 leading-tight mb-6">
        Digitalisez la gestion de votre 
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-sky-500 to-blue-600">
          flotte de taxis
        </span>
      </h1>

      <!-- Subheadline -->
      <p class="text-xl text-slate-600 mb-10 max-w-2xl mx-auto leading-relaxed">
        AfriMobilis aide les syndicats et propriétaires de taxis à structurer leur gestion, 
        suivre les versements et garantir la conformité documentaire.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-12">
        <a href="#demo" class="w-full sm:w-auto bg-sky-600 hover:bg-sky-700 text-white px-8 py-4 rounded-xl font-semibold text-lg transition shadow-xl shadow-sky-600/20 flex items-center justify-center gap-2">
          Demander une démo gratuite
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
        </a>
        <a href="#fonctionnalites" class="w-full sm:w-auto bg-white hover:bg-slate-50 text-slate-700 border border-slate-300 px-8 py-4 rounded-xl font-semibold text-lg transition flex items-center justify-center gap-2">
          Voir les fonctionnalités
        </a>
      </div>

      <!-- Social proof -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-6 text-slate-500">
        <div class="flex -space-x-3">
          <div class="w-10 h-10 rounded-full bg-gradient-to-br from-orange-400 to-red-500 border-2 border-white"></div>
          <div class="w-10 h-10 rounded-full bg-gradient-to-br from-green-400 to-emerald-500 border-2 border-white"></div>
          <div class="w-10 h-10 rounded-full bg-gradient-to-br from-purple-400 to-indigo-500 border-2 border-white"></div>
          <div class="w-10 h-10 rounded-full bg-gradient-to-br from-sky-400 to-blue-500 border-2 border-white"></div>
        </div>
        <p class="text-sm">
          <span class="font-semibold text-slate-900">+150 véhicules</span> déjà gérés à Grand-Bassam
        </p>
      </div>
    </div>

    <!-- Dashboard Preview -->
    <div class="mt-16 relative">
      <div class="absolute -inset-4 bg-gradient-to-r from-sky-500 to-blue-600 rounded-2xl blur-2xl opacity-20"></div>
      <div class="relative bg-slate-900 rounded-xl shadow-2xl overflow-hidden border border-slate-800">
        <div class="flex items-center gap-2 px-4 py-3 bg-slate-800 border-b border-slate-700">
          <div class="w-3 h-3 rounded-full bg-red-500"></div>
          <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
          <div class="w-3 h-3 rounded-full bg-green-500"></div>
          <span class="ml-4 text-slate-400 text-sm">app.afrimobilis.com</span>
        </div>
        <div class="p-8 bg-slate-900">
          <div class="grid grid-cols-3 gap-4 mb-6">
            <div class="bg-slate-800 rounded-lg p-4">
              <div class="text-slate-400 text-sm mb-1">Véhicules actifs</div>
              <div class="text-2xl font-bold text-white">147</div>
            </div>
            <div class="bg-slate-800 rounded-lg p-4">
              <div class="text-slate-400 text-sm mb-1">Versements ce mois</div>
              <div class="text-2xl font-bold text-emerald-400">8.2M FCFA</div>
            </div>
            <div class="bg-slate-800 rounded-lg p-4">
              <div class="text-slate-400 text-sm mb-1">Conformité</div>
              <div class="text-2xl font-bold text-sky-400">94%</div>
            </div>
          </div>
          <div class="bg-slate-800 rounded-lg p-4 h-32 flex items-center justify-center">
            <span class="text-slate-500">Graphique de rentabilité</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
