---
const plans = [
  {
    name: "Starter",
    price: "500",
    description: "Par véhicule / mois",
    features: [
      "Gestion jusqu'à 20 véhicules",
      "Dashboard syndicat",
      "Suivi des versements",
      "Alertes conformité",
      "Support par email"
    ],
    cta: "Commencer gratuitement",
    popular: false
  },
  {
    name: "Pro",
    price: "400",
    description: "Par véhicule / mois",
    features: [
      "Véhicules illimités",
      "Toutes les fonctionnalités Starter",
      "Application mobile",
      "Notifications WhatsApp",
      "Rapports avancés",
      "Support prioritaire"
    ],
    cta: "Demander une démo",
    popular: true
  },
  {
    name: "Enterprise",
    price: "Sur mesure",
    description: "Pour les grands groupes",
    features: [
      "Multi-sites / Multi-pays",
      "API dédiée",
      "Intégrations personnalisées",
      "Formation sur site",
      "Account manager dédié",
      "SLA garanti"
    ],
    cta: "Nous contacter",
    popular: false
  }
];
---

<section id="tarifs" class="py-20 bg-slate-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 mb-4">
        Des tarifs adaptés à votre taille
      </h2>
      <p class="text-lg text-slate-600">
        Commencez gratuitement, évoluez selon vos besoins. Sans engagement.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8 max-w-6xl mx-auto">
      {plans.map((plan) => (
        <div class={`relative rounded-2xl p-8 ${plan.popular ? 'bg-slate-900 text-white shadow-2xl scale-105' : 'bg-white border border-slate-200'}`}>
          {plan.popular && (
            <div class="absolute -top-4 left-1/2 -translate-x-1/2">
              <span class="bg-sky-500 text-white px-4 py-1 rounded-full text-sm font-semibold">
                Plus populaire
              </span>
            </div>
          )}
          
          <div class="mb-6">
            <h3 class={`text-xl font-bold mb-2 ${plan.popular ? 'text-white' : 'text-slate-900'}`}>{plan.name}</h3>
            <div class="flex items-baseline gap-1">
              <span class={`text-4xl font-bold ${plan.popular ? 'text-white' : 'text-slate-900'}`}>{plan.price}</span>
              {plan.price !== "Sur mesure" && <span class="text-lg">FCFA</span>}
            </div>
            <p class={`text-sm mt-1 ${plan.popular ? 'text-slate-300' : 'text-slate-500'}`}>{plan.description}</p>
          </div>

          <ul class="space-y-3 mb-8">
            {plan.features.map((feature) => (
              <li class="flex items-start gap-3">
                <svg class={`w-5 h-5 flex-shrink-0 mt-0.5 ${plan.popular ? 'text-sky-400' : 'text-sky-600'}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span class={plan.popular ? 'text-slate-200' : 'text-slate-600'}>{feature}</span>
              </li>
            ))}
          </ul>

          <a 
            href="#demo" 
            class={`block w-full text-center py-3 rounded-lg font-semibold transition ${
              plan.popular 
                ? 'bg-sky-500 hover:bg-sky-600 text-white' 
                : 'bg-slate-100 hover:bg-slate-200 text-slate-900'
            }`}
          >
            {plan.cta}
          </a>
        </div>
      ))}
    </div>

    <p class="text-center text-slate-500 mt-8 text-sm">
      * Prix en FCFA. Facturation mensuelle. Résiliation possible à tout moment.
    </p>
  </div>
</section>
