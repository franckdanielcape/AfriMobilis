---
const benefits = [
  {
    stat: "40%",
    label: "de temps gagné",
    description: "sur la gestion administrative"
  },
  {
    stat: "95%",
    label: "de conformité",
    description: "grâce aux alertes automatiques"
  },
  {
    stat: "30%",
    label: "de réduction",
    description: "des retards de versements"
  }
];
---

<section id="avantages" class="py-20 bg-slate-900 text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <div>
        <h2 class="text-3xl sm:text-4xl font-bold mb-6">
          Pourquoi les syndicats choisissent AfriMobilis ?
        </h2>
        <p class="text-slate-300 text-lg mb-8 leading-relaxed">
          Fini les registres papier et les tableaux Excel. AfriMobilis centralise toute votre 
          gestion en une seule plateforme sécurisée, accessible de n'importe où.
        </p>
        
        <ul class="space-y-4">
          <li class="flex items-start gap-3">
            <div class="w-6 h-6 rounded-full bg-sky-500 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            </div>
            <span class="text-slate-200">Interface en français, adaptée au contexte africain</span>
          </li>
          <li class="flex items-start gap-3">
            <div class="w-6 h-6 rounded-full bg-sky-500 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            </div>
            <span class="text-slate-200">Notifications WhatsApp pour les alertes importantes</span>
          </li>
          <li class="flex items-start gap-3">
            <div class="w-6 h-6 rounded-full bg-sky-500 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            </div>
            <span class="text-slate-200">Support local et formation des équipes</span>
          </li>
          <li class="flex items-start gap-3">
            <div class="w-6 h-6 rounded-full bg-sky-500 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            </div>
            <span class="text-slate-200">Sécurité des données et conformité RGPD</span>
          </li>
        </ul>
      </div>

      <div class="grid gap-6">
        {benefits.map((benefit) => (
          <div class="bg-slate-800 rounded-2xl p-6 border border-slate-700">
            <div class="text-4xl font-bold text-sky-400 mb-1">{benefit.stat}</div>
            <div class="text-lg font-semibold text-white mb-1">{benefit.label}</div>
            <div class="text-slate-400">{benefit.description}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
