{
    "name": "@afrimobilis/api",
    "version": "1.0.0",
    "description": "Backend API for AfriMobilis",
    "main": "dist/index.js",
    "scripts": {
        "dev": "ts-node check-env.ts && nodemon src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "lint": "eslint . --ext .ts",
        "check-env": "ts-node check-env.ts",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@supabase/supabase-js": "^2.39.0",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "helmet": "^7.1.0",
        "morgan": "^1.10.0",
        "node-cron": "^3.0.3"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jest": "^29.5.11",
        "@types/morgan": "^1.9.9",
        "@types/node": "^20.10.4",
        "@types/node-cron": "^3.0.11",
        "jest": "^29.7.0",
        "ts-jest": "^29.1.1",
        "ts-node": "^10.9.2",
        "typescript": "^5.3.3"
    },
    "optionalDependencies": {
        "redis": "^4.6.0",
        "zod": "^3.22.0"
    }
}
