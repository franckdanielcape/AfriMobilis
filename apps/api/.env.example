# URL de votre projet Supabase
SUPABASE_URL=https://votre-projet.supabase.co

# Clé Service Role (IMPORTANT: ce n'est PAS la anon key!)
# Pour la trouver: Supabase Dashboard > Project Settings > API > service_role key
# Cette clé bypass RLS - ne la commitez jamais!
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Redis (optionnel pour le cache)
REDIS_URL=redis://localhost:6379

# Port du serveur
PORT=4000
